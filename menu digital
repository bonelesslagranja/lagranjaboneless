
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Menú — Boneless La Granja</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:ital,wght@0,400;0,600;0,700;0,900;1,400;1,600&family=Barlow:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --rojo:#7A0000;
  --rojo2:#9B1C1C;
  --naranja:#C8470A;
  --oro:#B8843A;
  --oro2:#D4A854;
  --crema:#F5EDD8;
  --cafe:#1E0E03;
  --cafe2:#2E160A;
  --cafe3:#3A1C0C;
  --blanco:#FFF8F0;
  --gris:#c8b89a;
}
body{
  background:var(--cafe);
  color:var(--blanco);
  font-family:'Barlow Condensed',sans-serif;
  max-width:595px;
  margin:0 auto;
}

/* PAGE */
.page{
  width:100%;
  min-height:842px;
  position:relative;
  overflow:hidden;
  background:var(--cafe2);
  border-bottom:3px solid var(--rojo);
}

/* BG WATERMARK */
.wm{
  position:absolute;
  inset:0;
  background-size:cover;
  background-position:center;
  opacity:0.13;
  filter:saturate(0.6);
}
.wm.right{ background-position:right center; opacity:0.16; }

/* COVER PAGE */
.cover{
  min-height:320px;
  position:relative;
  overflow:hidden;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:flex-end;
  padding-bottom:30px;
}
.cover-bg{
  position:absolute;
  inset:0;
  background-size:cover;
  background-position:center 35%;
  filter:brightness(0.35) saturate(1.1);
}
.cover-grad{
  position:absolute;
  inset:0;
  background:linear-gradient(180deg, rgba(30,14,3,0) 20%, rgba(30,14,3,0.7) 60%, var(--cafe2) 100%);
}
.cover-content{position:relative;z-index:2;text-align:center;padding:0 20px;}
.cover-est{
  font-family:'Barlow Condensed',sans-serif;
  font-size:11px;letter-spacing:4px;
  color:var(--oro2);
  margin-bottom:6px;
  opacity:0.9;
}
.cover-title{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(52px,14vw,80px);
  line-height:0.85;
  color:var(--crema);
  letter-spacing:2px;
  text-shadow:0 4px 24px rgba(0,0,0,0.9);
}
.cover-title span{color:var(--naranja);}
.cover-sub{
  font-family:'Barlow Condensed',sans-serif;
  font-style:italic;
  font-size:16px;
  color:var(--oro2);
  margin-top:8px;
  letter-spacing:1px;
}

/* SECTION DIVIDER — replicates PDF style */
.sec-head{
  display:flex;
  align-items:center;
  gap:0;
  margin:0;
  position:relative;
  z-index:2;
}
.sec-head-bar{
  background:var(--rojo);
  padding:8px 18px 8px 20px;
  display:flex;
  align-items:center;
  gap:8px;
  flex:1;
}
.sec-head-icon{font-size:18px;}
.sec-head-title{
  font-family:'Bebas Neue',sans-serif;
  font-size:20px;
  letter-spacing:2px;
  color:var(--crema);
}
.sec-desc{
  font-size:12px;
  color:var(--gris);
  font-style:italic;
  padding:8px 20px 10px;
  line-height:1.4;
  position:relative;
  z-index:2;
  background:rgba(30,14,3,0.5);
}

/* ITEM ROW */
.item{
  display:flex;
  justify-content:space-between;
  align-items:flex-start;
  padding:9px 20px;
  border-bottom:1px solid rgba(255,255,255,0.05);
  position:relative;
  z-index:2;
  gap:12px;
}
.item:last-child{border-bottom:none;}
.item-left{flex:1;}
.item-name{
  font-family:'Barlow Condensed',sans-serif;
  font-weight:700;
  font-size:15px;
  color:var(--crema);
  line-height:1.15;
}
.item-name.bold{font-size:16px;color:white;}
.item-desc2{
  font-size:11.5px;
  color:var(--gris);
  line-height:1.4;
  margin-top:2px;
}
.item-combo{
  font-size:11px;
  color:var(--oro);
  margin-top:3px;
}
.precio{
  font-family:'Bebas Neue',sans-serif;
  font-size:22px;
  color:var(--naranja);
  flex-shrink:0;
  letter-spacing:0.5px;
  margin-top:1px;
}
.precio.big{font-size:26px;}

/* BADGE INLINE */
.bdg{
  display:inline-block;
  font-family:'Barlow Condensed',sans-serif;
  font-weight:700;
  font-size:9.5px;
  letter-spacing:1.5px;
  padding:2px 7px;
  border-radius:2px;
  margin-right:5px;
  vertical-align:middle;
  text-transform:uppercase;
}
.bdg-r{background:var(--rojo);color:var(--crema);}
.bdg-o{background:var(--naranja);color:white;}
.bdg-g{background:var(--oro);color:var(--cafe);}

/* PROMO BOX */
.promo{
  margin:6px 20px 8px;
  background:rgba(120,20,0,0.35);
  border:1px solid rgba(180,60,0,0.4);
  border-left:3px solid var(--naranja);
  border-radius:6px;
  padding:9px 14px;
  position:relative;
  z-index:2;
}
.promo-t{
  font-family:'Barlow Condensed',sans-serif;
  font-weight:700;
  font-size:13px;
  color:var(--oro2);
  margin-bottom:3px;
}
.promo-d{font-size:11px;color:rgba(245,237,216,0.8);line-height:1.4;}

/* CUPÓN */
.cupon{
  margin:4px 20px 8px;
  background:rgba(30,14,3,0.6);
  border:1px dashed var(--oro);
  border-radius:5px;
  padding:7px 12px;
  font-size:11px;
  color:var(--oro2);
  position:relative;
  z-index:2;
  display:flex;
  align-items:center;
  gap:6px;
}

/* SALSAS GRID */
.salsas{
  display:grid;
  grid-template-columns:1fr 1fr 1fr;
  gap:6px;
  padding:10px 20px 14px;
  position:relative;
  z-index:2;
}
.salsa{
  background:rgba(122,0,0,0.35);
  border:1px solid rgba(122,0,0,0.55);
  border-radius:6px;
  padding:7px 8px;
  font-weight:700;
  font-size:12px;
  color:var(--crema);
  text-align:center;
}

/* FAMILIAR CARD */
.fam-card{
  margin:6px 16px 0;
  background:rgba(30,14,3,0.7);
  border:1px solid rgba(200,150,62,0.2);
  border-left:3px solid var(--rojo);
  border-radius:8px;
  padding:11px 14px;
  position:relative;
  z-index:2;
}
.fam-header{
  display:flex;
  justify-content:space-between;
  align-items:flex-start;
  margin-bottom:7px;
}
.fam-name{
  font-family:'Barlow Condensed',sans-serif;
  font-weight:900;
  font-size:17px;
  color:white;
  line-height:1.1;
}
.fam-list{
  list-style:none;
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:1px 10px;
}
.fam-list li{
  font-size:11px;
  color:var(--gris);
  padding:1.5px 0;
}
.fam-list li::before{content:"✦ ";color:var(--oro);font-size:8px;}
.fam-personas{
  font-size:11px;
  color:var(--oro);
  font-style:italic;
  margin-top:7px;
  padding-top:6px;
  border-top:1px solid rgba(255,255,255,0.07);
}

/* FOOTER */
.footer{
  background:var(--cafe2);
  border-top:2px solid var(--rojo);
  padding:20px;
  text-align:center;
}
.footer-title{
  font-family:'Bebas Neue',sans-serif;
  font-size:26px;
  letter-spacing:2px;
  color:var(--crema);
}
.footer-sub{font-size:12px;color:var(--oro);font-style:italic;margin-top:2px;}
.footer-line{height:1px;background:rgba(200,150,62,0.2);margin:12px 0;}
.footer-info{font-size:11.5px;color:var(--gris);line-height:1.9;}
.footer-handle{font-size:10px;color:rgba(245,237,216,0.3);letter-spacing:3px;margin-top:10px;}

.spacer{height:8px;position:relative;z-index:2;}
</style>
</head>
